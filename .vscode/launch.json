            "url": "c:\\Users\\matty\\.vscode\\extensions\\ms-edgedevtools.vscode-edge-devtools-2.1.10\\out\\startpage\\index.html", // Provide your project's url to finish configuring // Provide your project's url to finish configuring // Provide your project's url to finish configuring // Provide your project's url to finish configuring // Provide your project's url to finish configuring // Provide your project's url to finish configuring
